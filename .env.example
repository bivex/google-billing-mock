# Mock Server environment variables
# Copy to .env and adjust as needed

MOCK_SERVER_PORT=8080
MOCK_LOG_LEVEL=info
MOCK_METRICS_ENABLED=true
MOCK_METRICS_PATH=/metrics

# Scenario configuration
MOCK_MOCK_SCENARIOS_PATH=config/scenarios/default.json
MOCK_MOCK_DEFAULT_LATENCY_MS=0
MOCK_MOCK_ERROR_RATE=0.0

# Auth (disabled in dev)
MOCK_AUTH_MOCK_ENABLED=false
